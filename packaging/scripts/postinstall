#!/bin/bash
set -euo pipefail

APP_DIR="/usr/local/lib/mac-toolkit"
VENV_DIR="${APP_DIR}/.venv"
PYTHON_BIN="${PYTHON:-}"
BOOTSTRAP_PKG="$(find "${APP_DIR}/bootstrap" -maxdepth 1 -name 'Python-*.pkg' | sort | tail -1)"

find_python() {
  for candidate in \
    "${PYTHON_BIN}" \
    /Library/Frameworks/Python.framework/Versions/3.11/bin/python3 \
    /Library/Frameworks/Python.framework/Versions/3.12/bin/python3 \
    /Library/Frameworks/Python.framework/Versions/3.13/bin/python3 \
    /usr/local/bin/python3 \
    /opt/homebrew/bin/python3 \
    /usr/bin/python3
  do
    if [ -n "${candidate}" ] && command -v "${candidate}" >/dev/null 2>&1; then
      if "${candidate}" - <<'PY' >/dev/null 2>&1
import sys
raise SystemExit(0 if sys.version_info >= (3, 11) else 1)
PY
      then
        echo "${candidate}"
        return 0
      fi
    fi
  done
  return 1
}

PYTHON_BIN="$(find_python || true)"
if [ -z "${PYTHON_BIN}" ]; then
  if [ -z "${BOOTSTRAP_PKG}" ] || [ ! -f "${BOOTSTRAP_PKG}" ]; then
    echo "Python 3.11+ is required and no bootstrap Python package was bundled." >&2
    exit 1
  fi
  echo "Installing bundled Python runtime from ${BOOTSTRAP_PKG}"
  /usr/sbin/installer -pkg "${BOOTSTRAP_PKG}" -target /
  PYTHON_BIN="$(find_python || true)"
fi

if [ -z "${PYTHON_BIN}" ]; then
  echo "Python 3.11+ could not be found after bootstrap installation." >&2
  exit 1
fi

"${PYTHON_BIN}" -m venv "${VENV_DIR}"
"${VENV_DIR}/bin/python" -m pip install --no-index --find-links "${APP_DIR}/wheelhouse" --upgrade pip || \
  "${VENV_DIR}/bin/python" -m pip install --upgrade pip

if ! "${VENV_DIR}/bin/python" -m pip install --no-index --find-links "${APP_DIR}/wheelhouse" "${APP_DIR}"; then
  echo "Bundled wheels were not compatible with this Mac; retrying with PyPI." >&2
  "${VENV_DIR}/bin/python" -m pip install "${APP_DIR}"
fi

mkdir -p /usr/local/bin
cat > /usr/local/bin/mactoolkit <<'SH'
#!/bin/bash
exec /usr/local/lib/mac-toolkit/.venv/bin/mactoolkit "$@"
SH
chmod 0755 /usr/local/bin/mactoolkit

cat > /usr/local/bin/mactoolkit-gui <<'SH'
#!/bin/bash
exec /usr/local/lib/mac-toolkit/.venv/bin/python /usr/local/lib/mac-toolkit/main_gui.py "$@"
SH
chmod 0755 /usr/local/bin/mactoolkit-gui

if [ -d "/Applications/Mac Toolkit.app" ]; then
  chmod 0755 "/Applications/Mac Toolkit.app/Contents/MacOS/Mac Toolkit"
fi

exit 0
